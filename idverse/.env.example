# IDVerse Bruno Collection — Environment Variables
# Copy this file to .env.local, .env.dev, or .env.prod and fill in values.
# These files are gitignored.

# App base URL
BASE_URL=http://localhost:19746

# Web UI auth key (AUTH_KEY in the app's .env)
AUTH_KEY=

# IDVerse upstream API credentials
IDVERSE_CLIENT_ID=
IDVERSE_CLIENT_SECRET=
IDVERSE_OAUTH_URL=https://us.demo.idkit.co/api/3.5/oauthToken
IDVERSE_API_URL=https://us.demo.idkit.co/api/3.5/sendSms

# Upstream access token — obtained by running upstream/get-oauth-token
IDVERSE_ACCESS_TOKEN=

# Webhook JWT token — obtained from server logs after POST /api/verify
# Look for "notifyUrlCompleteAuthKey" in the log, strip the "Bearer " prefix
WEBHOOK_JWT_TOKEN=

# JWT secret (same as JWT_SECRET_KEY in the app's .env)
JWT_SECRET_KEY=

# Webhook callback URLs
NOTIFY_URL_COMPLETE=http://localhost:19746/api/webhook
NOTIFY_URL_EVENT=http://localhost:19746/api/webhook
